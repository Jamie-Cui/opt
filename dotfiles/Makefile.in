.PHONY: deploy clean install

FONT_SIZE = @FONT_SIZE@

deploy:
	@find . -type f \( -name "*.conf" -o -name "*.ini" -o -name "*.yaml" -o -name "config" \) \
		-not -path "./.agent-shell/*" \
		-not -path "./.git/*" \
		-exec sed -i 's/{dotfont}/$(FONT_SIZE)/g' {} \;
	@echo "Deployed: replaced {dotfont} with $(FONT_SIZE)"

clean:
	@find . -type f \( -name "*.conf" -o -name "*.ini" -o -name "*.yaml" -o -name "config" \) \
		-not -path "./.agent-shell/*" \
		-not -path "./.git/*" \
		-exec sed -i 's/$(FONT_SIZE)/{dotfont}/g' {} \;
	@echo "Cleaned: reverted $(FONT_SIZE) to {dotfont}"

install: deploy
	@echo "Installing dotfiles..."
	@# Add your installation commands here

help:
	@echo "Available targets:"
	@echo "  make deploy   - Replace {dotfont} placeholders with configured font size"
	@echo "  make clean    - Revert font size back to {dotfont} placeholders"
	@echo "  make install  - Deploy and install dotfiles"
	@echo "  make help     - Show this help message"
	@echo ""
	@echo "Current font size: $(FONT_SIZE)"
