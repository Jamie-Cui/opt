#!/bin/sh
# Configure script for dotfiles

set -e

# Default values
FONT_SIZE=10
PREFIX="$HOME/.local"

# Parse command line arguments
while [ $# -gt 0 ]; do
	case "$1" in
		--font-size=*)
			FONT_SIZE="${1#*=}"
			;;
		--font-size)
			FONT_SIZE="$2"
			shift
			;;
		--prefix=*)
			PREFIX="${1#*=}"
			;;
		--prefix)
			PREFIX="$2"
			shift
			;;
		-h|--help)
			cat << EOF
Usage: ./configure [OPTIONS]

Options:
  --font-size=SIZE    Set font size (default: 10)
  --prefix=PATH       Set installation prefix (default: ~/.local)
  -h, --help          Show this help message

Examples:
  ./configure                    # Use defaults
  ./configure --font-size=12     # Set font size to 12
  ./configure --font-size 14     # Set font size to 14
EOF
			exit 0
			;;
		*)
			echo "Error: Unknown option: $1" >&2
			echo "Run './configure --help' for usage." >&2
			exit 1
			;;
	esac
	shift
done

# Validate font size is a number
case "$FONT_SIZE" in
	''|*[!0-9]*)
		echo "Error: FONT_SIZE must be a number, got '$FONT_SIZE'" >&2
		exit 1
		;;
esac

# Generate config.mk
cat > config.mk << EOF
# Generated by configure
FONT_SIZE = $FONT_SIZE
PREFIX = $PREFIX
EOF

# Generate Makefile from Makefile.in
sed -e "s|@FONT_SIZE@|$FONT_SIZE|g" \
    -e "s|@PREFIX@|$PREFIX|g" \
    Makefile.in > Makefile

# Report configuration
cat << EOF

Configuration:
  Font size:  $FONT_SIZE
  Prefix:     $PREFIX

Now run 'make' to deploy.
EOF
