# This Makefile was generated by ./configure
# To change configuration, run ./configure again

.PHONY: deploy clean install help reconfigure

FONT_SIZE = 10

deploy:
	@find . -type f \( -name "*.conf" -o -name "*.ini" -o -name "*.yaml" -o -name "config" \) \
		-not -path "./.agent-shell/*" \
		-not -path "./.git/*" \
		-exec sed -i 's/{dotfont}/$(FONT_SIZE)/g' {} \;
	@echo "Deployed: replaced {dotfont} with $(FONT_SIZE)"

clean:
	@find . -type f \( -name "*.conf" -o -name "*.ini" -o -name "*.yaml" -o -name "config" \) \
		-not -path "./.agent-shell/*" \
		-not -path "./.git/*" \
		-exec sed -i 's/$(FONT_SIZE)/{dotfont}/g' {} \;
	@echo "Cleaned: reverted $(FONT_SIZE) to {dotfont}"

reconfigure:
	@echo "Run ./configure with desired options:"
	@echo "  ./configure                    # Use defaults (font-size=10)"
	@echo "  ./configure --font-size=12     # Set font size to 12"
	@echo "  ./configure --help             # Show all options"

install: deploy
	@echo "Installing dotfiles..."
	@# Add your installation commands here

help:
	@echo "Available targets:"
	@echo "  make deploy      - Replace {dotfont} with configured font size"
	@echo "  make clean       - Revert font size back to {dotfont}"
	@echo "  make install     - Deploy and install dotfiles"
	@echo "  make reconfigure - Show configure options"
	@echo "  make help        - Show this help message"
	@echo ""
	@echo "Current font size: $(FONT_SIZE)"
	@echo ""
	@echo "To change configuration, run ./configure"
