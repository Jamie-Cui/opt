# XMODIFIERS=@im=fcitx imsettings-switch fcitx5 bindsym Control+space exec
# --no-startup-id fcitx5-remote -t

# kill focused window
bindsym $meta+q kill

# lock the i3 session
bindsym $meta+shift+q exec i3lock

